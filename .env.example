# Copy this file to backend/.env and fill in your real key.
# Get a free key at https://aistudio.google.com ("Get API key").
# If GOOGLE_API_KEY is missing, the backend runs in MOCK mode:
# every agent works end-to-end with deterministic canned responses,
# so the full demo flow can be exercised without a key.
GOOGLE_API_KEY=your-key-here

# Frontend (set in frontend/.env.local or the Vercel dashboard)
NEXT_PUBLIC_API_URL=http://localhost:8000
