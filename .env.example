# Copy this file to backend/.env and fill in your real key.
# Get a free key at https://aistudio.google.com ("Get API key").
# If GOOGLE_API_KEY is missing, the backend runs in MOCK mode:
# every agent works end-to-end with deterministic canned responses,
# so the full demo flow can be exercised without a key.
# One key, or several comma-separated keys from different Google accounts.
# With multiple keys the backend rotates automatically when one hits the
# free-tier rate limit: GOOGLE_API_KEY=key1,key2
GOOGLE_API_KEY=your-key-here

# Optional model overrides. Defaults are the current free-tier models
# (gemini-2.5-flash / gemini-embedding-001). If Google retires a model from
# the free tier (429 with "limit: 0"), change it here — no code change needed.
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001

# Groq — automatic fallback when Gemini is rate-limited (real AI, free tier).
# Get a key at https://console.groq.com. Optional but recommended for demos.
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Set to 0 for the judged/deployed build so it fails honestly instead of
# returning canned data if ALL real providers are exhausted.
# ALLOW_MOCK_FALLBACK=1

# ── WhatsApp channel (optional) ──────────────────────────────────────────
# From Meta's WhatsApp Business Platform. The app must be deployed at a public
# HTTPS URL and this webhook registered: {your-url}/whatsapp/webhook
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=pension-saathi-verify

# ── Server-side voice (for WhatsApp voice notes) ─────────────────────────
# Sarvam is the default for BOTH sides (tuned for Indian languages). Override
# to elevenlabs on either side if you want ElevenLabs' voices instead.
# TTS_PROVIDER=sarvam | elevenlabs    STT_PROVIDER=sarvam | elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
SARVAM_API_KEY=
# TTS_PROVIDER=sarvam
# STT_PROVIDER=sarvam

# ── Dedicated web search (do NOT use Gemini grounding for this) ──────────
# Set ONE key; the backend picks it up automatically. Pin a provider with
# WEB_SEARCH_PROVIDER if you have multiple keys set.
TAVILY_API_KEY=
SERPER_API_KEY=
BRAVE_SEARCH_API_KEY=
# WEB_SEARCH_PROVIDER=tavily

# ── Server-side OCR + at-rest encryption for document uploads ────────────
# Documents are OCR'd locally (Tesseract) so raw images never leave the box.
# Install: apt-get install -y tesseract-ocr tesseract-ocr-hin tesseract-ocr-tel
# OCR_LANGS follows Tesseract's convention, e.g. hin+eng, tel+eng.
# OCR_LANGS=hin+eng
# Windows only: if tesseract.exe is installed but not on PATH inside your
# venv, point us straight at it. Linux/Mac usually don't need this.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# OCR_ENCRYPTION_KEY: base64-encoded 16/24/32-byte key. Extracted text is
# AES-GCM-encrypted with this key before it's written to the DB. Unset in
# dev is fine — a per-process ephemeral key is used (data non-recoverable
# after restart, which is the safer default for a demo).
# OCR_ENCRYPTION_KEY=

# Frontend (set in frontend/.env.local or the Vercel dashboard)
NEXT_PUBLIC_API_URL=http://localhost:8000
